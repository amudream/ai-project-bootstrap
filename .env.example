# Copy this file to .env.local. Never commit .env.local.
# Use either OpenAI's public endpoint or any OpenAI-compatible local/proxy endpoint.

OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="replace-with-your-real-key-in-.env.local-only"
OPENAI_MODEL="gpt-5.5"

# responses | chat-completions
OPENAI_API_MODE="responses"

# Optional model behavior controls used by your own wrappers.
OPENAI_REASONING_EFFORT="high"
OPENAI_VERBOSITY="high"

# Optional domain connector placeholders. Keep real values in .env.local only.
MARKET_DATA_PROVIDER=""
MARKET_DATA_API_KEY=""
ALIBABA_EXPORT_PATH=""
CRM_EXPORT_PATH=""
ANALYTICS_EXPORT_PATH=""
